# Admin panel authentication — override via Kubernetes Secret in production
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme

# Cloudflare Tunnel token — get it from Zero Trust → Tunnels → your tunnel
# CLOUDFLARE_TUNNEL_TOKEN=<paste tunnel token here>

# Camera RTSP URL (already defaulted in stream.py; override here if needed)
# RTSP_URL=rtsp://admin:admin123@192.168.1.169:554/cam/realmonitor?channel=1&subtype=0
